{
  "manifest_version": 3,
  "name": "AI Fact Checker",
  "version": "2.1",
  "description": "AI-powered fact-checking for news articles and video content using OpenAI Whisper, GPT-4.1-nano, and ClaimBuster.",
  "permissions": [
    "activeTab",
    "scripting", 
    "tabs",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "*://*.bild.de/*",
    "*://*.spiegel.de/*",
    "*://*.welt.de/*",
    "*://*.faz.net/*",
    "*://*.sueddeutsche.de/*",
    "*://*.zeit.de/*",
    "*://*.nius.de/*",
    "*://*.n-tv.de/*",
    "*://*.compact-online.de/*",
    "*://*.bbc.com/*",
    "*://*.bbc.co.uk/*",
    "*://*.cnn.com/*",
    "*://*.theguardian.com/*",
    "*://*.nytimes.com/*",
    "*://*.washingtonpost.com/*",
    "*://*.reuters.com/*",
    "*://*.aljazeera.com/*",
    "*://*.foxnews.com/*",
    "*://*.nbcnews.com/*",
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://*.tiktok.com/*",
    "*://*.m.tiktok.com/*",
    "https://api.openai.com/*",
    "https://idir.uta.edu/claimbuster/api/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bild.de/*",
        "*://*.spiegel.de/*",
        "*://*.welt.de/*",
        "*://*.faz.net/*",
        "*://*.sueddeutsche.de/*",
        "*://*.zeit.de/*",
        "*://*.nius.de/*",
        "*://*.n-tv.de/*",
        "*://*.compact-online.de/*",
        "*://*.bbc.com/*",
        "*://*.bbc.co.uk/*",
        "*://*.cnn.com/*",
        "*://*.theguardian.com/*",
        "*://*.nytimes.com/*",
        "*://*.washingtonpost.com/*",
        "*://*.reuters.com/*",
        "*://*.aljazeera.com/*",
        "*://*.foxnews.com/*",
        "*://*.nbcnews.com/*",
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.tiktok.com/*",
        "*://*.m.tiktok.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Fact Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
  {
    "resources": [
      "ground_truth/data/articles/*.json",
      "ground_truth/evaluate.js"
    ],
    "matches": ["<all_urls>"]
  }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}